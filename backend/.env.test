# Backend environment variables - Test Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/citation_llm_test
SECRET_KEY=test-secret-key-for-testing
JWT_SECRET_KEY=test-jwt-secret-for-testing

# LLM API Keys (placeholder for testing - won't actually call APIs without real keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model configurations
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
GOOGLE_MODEL=gemini-1.5-flash

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Chunking configuration (tokens)
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# Vector search
TOP_K=5

# File upload
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf
